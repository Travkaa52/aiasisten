# --- Telegram (обязательно, Telethon user-account, НЕ Bot API) ---
API_ID=
API_HASH=
SESSION=

# ID владельца(ев) через запятую — эти аккаунты считаются owner
OWNER_IDS=

# --- AI providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_WHISPER_MODEL=whisper-1

# --- Storage ---
DB_PATH=./data/assistant.db
CACHE_DIR=./assistant/cache/storage
LOG_DIR=./logs
LOG_LEVEL=INFO

# --- Runtime ---
# Сколько секунд слушать события за один запуск GitHub Actions job
RUN_DURATION_SECONDS=240
RECONNECT_MAX_ATTEMPTS=5
RECONNECT_BASE_DELAY=2.0

# --- Antispam ---
ANTISPAM_MAX_MESSAGES=8
ANTISPAM_WINDOW_SECONDS=10
ANTISPAM_AUTO_BLACKLIST=true

# --- Access ---
WHITELIST_MODE=false

# --- Memory ---
MEMORY_CONTEXT_MESSAGES=20

# --- Plugins ---
PLUGINS_ENABLED=true
